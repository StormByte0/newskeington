:: AuthorMacros [script]
/* =========================================================================
 * Module: author — passage-facing macros for state mutation.
 *
 * These macros let passage authors add items, equip/unequip, save/load
 * outfits, and modify stats WITHOUT writing <<run>> or touching JS. Each
 * macro wraps the corresponding setup.inventory / setup.outfits API call
 * and auto-refreshes the UI (no manual <<uiRefresh>> needed).
 *
 * ┌─ CATALOG VS STORYINIT — PERFORMANCE ───────────────────────────────┐
 * │                                                                     │
 * │  The item/quest catalog stays in JS (12-catalog.twee) because:      │
 * │  1. SugarCube strips functions from $vars during save serialization │
 * │     — a StoryInit catalog would lose every onUse/onEquip/status().  │
 * │  2. $vars bloat every save file; JS catalog lives in code only.     │
 * │  3. JS [script] passages run once at load; StoryInit re-runs on     │
 * │     every save load / restart.                                      │
 * │  4. Read performance is identical (O(1) object lookup).             │
 * │                                                                     │
 * │  The catalog is AUTHOR-EDITED but not AUTHOR-RUN — authors add      │
 * │  setup.items.register(...) calls to 12-catalog.twee using the       │
 * │  template at the top of that file, then give items to the player    │
 * │  via the <<itemAdd>> macro in story passages.                       │
 * │                                                                     │
 * │  RE-RENDER PERFORMANCE: setup.ui.refresh() re-wikifies all          │
 * │  data-passage panels (~2ms each) + the open window tab (~5ms).      │
 * │  Refreshes are coalesced (deferred via setTimeout, deduped) so      │
 * │  multiple mutations in one tick produce one refresh. For this      │
 * │  project's scale (~20 items, ~5 quests) the cost is trivial.        │
 * └─────────────────────────────────────────────────────────────────────┘
 *
 * MACRO REFERENCE (for passage authors):
 *
 *   <<itemAdd "potion_health" 2>>      Add 2 health potions to inventory
 *   <<itemAdd "sword_iron">>           Add 1 sword (qty defaults to 1)
 *   <<itemRemove "bread_loaf" 1>>      Remove 1 bread
 *   <<equip "sword_iron">>             Equip an item (must be in inventory)
 *   <<unequip "weapon">>               Unequip whatever's in the weapon slot
 *   <<outfitSave "Battle">>            Save current equipment as "Battle"
 *   <<outfitLoad "Battle">>            Load the "Battle" outfit preset
 *   <<outfitDelete "Battle">>          Delete the "Battle" preset
 *   <<statMod "gold" -50>>             Subtract 50 gold + refresh UI
 *   <<statMod "resources.money" -50>>  Subtract 50 money (dotted path)
 *   <<statMod "stats.str" 1>>          Add 1 Strength (dotted path)
 *   <<statusAdd "drunk">>              Add the "drunk" status effect
 *   <<statusRemove "drunk">>           Remove the "drunk" status effect
 *
 *   For conditionals (no macro needed — use the setup API directly):
 *     <<if setup.inventory.has("town_map")>> ... <</if>>
 *     <<if setup.inventory.isEquipped("sword_iron")>> ... <</if>>
 *     <<if setup.quests.status("find_magic_map") == "active">> ... <</if>>
 *
 *   For raw stat reads (standard SugarCube):
 *     <<if $gold >= 50>> ... <</if>>
 *     <<if $hp < $maxhp>> ... <</if>>
 * ========================================================================= */
(function () {
        "use strict";

        /* --- Item macros --- */

        Macro.add("itemAdd", {
                handler: function () {
                        if (!this.args.length) return this.error('usage: <<itemAdd "id" [qty]>>');
                        var id = String(this.args[0]);
                        var qty = this.args.length > 1 ? Number(this.args[1]) || 1 : 1;
                        setup.inventory.add(id, qty);
                }
        });

        Macro.add("itemRemove", {
                handler: function () {
                        if (!this.args.length) return this.error('usage: <<itemRemove "id" [qty]>>');
                        var id = String(this.args[0]);
                        var qty = this.args.length > 1 ? Number(this.args[1]) || 1 : 1;
                        setup.inventory.remove(id, qty);
                }
        });

        /* --- Equipment macros --- */

        Macro.add("equip", {
                handler: function () {
                        if (!this.args.length) return this.error('usage: <<equip "itemId">>');
                        setup.inventory.equip(String(this.args[0]));
                }
        });

        Macro.add("unequip", {
                handler: function () {
                        if (!this.args.length) return this.error('usage: <<unequip "slot">>');
                        setup.inventory.unequip(String(this.args[0]));
                }
        });

        /* --- Outfit macros --- */

        Macro.add("outfitSave", {
                handler: function () {
                        if (!this.args.length) return this.error('usage: <<outfitSave "name">>');
                        setup.outfits.save(String(this.args[0]));
                }
        });

        Macro.add("outfitLoad", {
                handler: function () {
                        if (!this.args.length) return this.error('usage: <<outfitLoad "name">>');
                        setup.outfits.load(String(this.args[0]));
                }
        });

        Macro.add("outfitDelete", {
                handler: function () {
                        if (!this.args.length) return this.error('usage: <<outfitDelete "name">>');
                        setup.outfits["delete"](String(this.args[0]));
                }
        });

        /* --- Stat modifier macro ---
         *    Wraps <<set $var += value>> + <<uiRefresh>> into one call.
         *    Accepts dotted paths into the nested data model:
         *      <<statMod "resources.money" -50>>
         *      <<statMod "stats.str" 1>>
         *      <<statMod "resources.stamina" 20>>
         *    Top-level names still work for backwards compatibility:
         *      <<statMod "gold" -50>>
         *    Use this when you want the UI to update immediately after
         *    changing a stat. For non-numeric stats or complex logic,
         *    use <<set ...>> + <<uiRefresh>> directly. */
        function resolvePath(root, path, create) {
                var parts = path.split(".");
                var node = root;
                for (var i = 0; i < parts.length - 1; i++) {
                        var key = parts[i];
                        if (node[key] == null) {
                                if (!create) return null;
                                node[key] = {};
                        }
                        node = node[key];
                }
                return { node: node, key: parts[parts.length - 1] };
        }

        Macro.add("statMod", {
                handler: function () {
                        if (this.args.length < 2) return this.error('usage: <<statMod "path" delta>>');
                        var path  = String(this.args[0]);
                        var delta = Number(this.args[1]);
                        if (isNaN(delta)) return this.error("statMod: delta must be a number");
                        var v = State.variables;
                        var resolved = resolvePath(v, path, true);
                        var current = Number(resolved.node[resolved.key]) || 0;
                        resolved.node[resolved.key] = current + delta;
                        setup.ui.refresh();
                }
        });

        /* --- Status macros ---
         *    Add/remove temporary conditions (drunk, hungover, blisters…).
         *    Status DEFINITIONS live in the status catalog (in 03-widgets.twee);
         *    $status[] only records which ids are active. */
        Macro.add("statusAdd", {
                handler: function () {
                        if (!this.args.length) return this.error('usage: <<statusAdd "id">>');
                        if (setup.status) setup.status.add(String(this.args[0]));
                        else setup.ui.refresh();
                }
        });

        Macro.add("statusRemove", {
                handler: function () {
                        if (!this.args.length) return this.error('usage: <<statusRemove "id">>');
                        if (setup.status) setup.status.remove(String(this.args[0]));
                        else setup.ui.refresh();
                }
        });
})();
